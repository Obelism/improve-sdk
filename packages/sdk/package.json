{
	"name": "@obelism/improve-sdk",
	"description": "Obelism Improve SDK",
	"version": "1.2.0",
	"keywords": [
		"ab-tests",
		"feature-flags",
		"typescript",
		"improve"
	],
	"license": "MIT",
	"author": "Obelism <hello@obelism.studio> (https://www.obelism.studio)",
	"repository": {
		"type": "git",
		"url": "https://github.com/Obelism/improve-sdk",
		"directory": "packages/sdk"
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.mjs",
			"require": "./dist/server.cjs"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.mjs",
			"require": "./dist/client.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts"
		}
	},
	"typesVersions": {
		"*": {
			"server": [
				"./dist/server.d.ts"
			],
			"client": [
				"./dist/client.d.ts"
			],
			"types": [
				"./dist/types.d.ts"
			]
		}
	},
	"scripts": {
		"build": "bunchee -m",
		"dev": "bunchee --watch --no-clean",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:ci": "vitest run",
		"lint": "npm-run-all --parallel lint:*",
		"lint:fix": "eslint --fix",
		"lint:types": "tsc --noEmit",
		"clean": "rm -rf ./node_modules && rm -rf ./dist && rm -rf ./.turbo"
	},
	"peerDependencies": {
		"ua-parser-js": "^2.0.0"
	},
	"devDependencies": {
		"@obelism/improve-sdk-eslint-config": "^0.0.0",
		"@obelism/improve-sdk-typescript-config": "^0.0.0",
		"bunchee": "^6.11.0",
		"eslint": "^10.6.0",
		"lint-staged": "^17.0.8",
		"npm-run-all": "^4.1.5",
		"typescript": "^6.0.3",
		"ua-parser-js": "^2.0.10",
		"vitest": "^4.1.9"
	}
}
